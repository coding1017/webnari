] pb-24 max-md:pt-[100px] max-md:pb-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-[800px] mx-auto px-10 max-md:px-5\",\"children\":[[\"$\",\"$L19\",null,{\"children\":[\"$\",\"nav\",null,{\"className\":\"flex items-center gap-2 text-sm text-ww-muted mb-8 font-head tracking-wider uppercase\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/glossary\",\"className\":\"hover:text-ww-pink transition-colors\",\"children\":\"Glossary\"}],[\"$\",\"span\",null,{\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-ww-text\",\"children\":\"French Knot\"}]]}]}],[\"$\",\"$L19\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"mb-10\",\"children\":[[\"$\",\"span\",null,{\"className\":\"inline-block px-3 py-1 text-[10px] font-head font-bold tracking-[0.15em] uppercase rounded-full bg-[rgba(168,85,247,0.15)] text-ww-purple2 mb-4\",\"children\":\"Techniques\"}],[\"$\",\"h1\",null,{\"className\":\"font-head font-black text-[clamp(36px,5vw,56px)] leading-[1.05] text-ww-white\",\"children\":\"French Knot\"}]]}]}],[\"$\",\"$L19\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"p-8 bg-ww-surface rounded-[20px] border border-ww-border mb-12\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-ww-text text-lg leading-[1.8]\",\"children\":\"A small, raised embroidery stitch created by wrapping thread around the needle before inserting it back into the fabric. French knots add dot-like texture and are used for eyes, flower centers, and decorative accents.\"}]}]}],[\"$\",\"$L19\",null,{\"children\":[\"$\",\"div\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-head font-black text-2xl text-ww-white mb-6\",\"children\":[\"More in \",\"Techniques\"]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-2 gap-4 max-md:grid-cols-1\",\"children\":[[\"$\",\"$L4\",\"sashiko\",{\"href\":\"/glossary/sashiko\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\",\"children\":\"Sashiko\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A Japanese form of decorative reinforcement stitching that uses a simple running stitch to create geometric patterns. Originally used to mend and strengthen worn clothing, sashiko is now prized for its meditative process and striking visual texture.\"}]]}],[\"$\",\"$L4\",\"blanket-stitch\",{\"href\":\"/glossary/blanket-stitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\",\"children\":\"Blanket Stitch\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A hand-sewing stitch used to finish raw edges, creating a series of evenly spaced loops along the fabric border. Each stitch locks the previous one in place, forming a durable and decorative edge binding.\"}]]}],[\"$\",\"$L4\",\"backstitch\",{\"href\":\"/glossary/backstitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\",\"children\":\"Backstitch\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A strong hand stitch where the needle goes backward into the end of the previous stitch before moving forward, creating a continuous, unbroken line. It is one of the most durable hand stitches and closely mimics a machine lockstitch.\"}]]}],[\"$\",\"$L4\",\"running-stitch\",{\"href\":\"/glossary/running-stitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\",\"children\":\"Running Stitch\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The most basic hand stitch, made by passing the needle in and out of the fabric at regular intervals. Simple and fast, it is used for basting, gathering, and decorative work like sashiko.\"}]]}],[\"$\",\"$L4\",\"whip-stitch\",{\"href\":\"/glossary/whip-stitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\",\"children\":\"Whip Stitch\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A simple overcast stitch that wraps thread diagonally over a fabric edge, used to join two pieces together or finish raw edges. Quick to execute and useful for closing openings after turning a piece right side out.\"}]]}],[\"$\",\"$L4\",\"applique\",{\"href\":\"/glossary/applique\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\",\"children\":\"Applique\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A technique where pieces of fabric are layered and stitched onto a base fabric to create decorative shapes and designs. Applique can be done by hand or machine and adds dimension and visual interest to flat surfaces.\"}]]}]]}]]}]}],[\"$\",\"$L19\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"mt-12\",\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary\",\"className\":\"inline-flex items-center gap-2 font-head text-sm font-bold tracking-[0.1em] uppercase text-ww-pink hover:text-ww-pink2 transition-colors\",\"children\":[[\"$\",\"svg\",null,{\"className\":\"w-4 h-4\",\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"stroke\":\"currentColor\",\"strokeWidth\":\"2\",\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"children\":[[\"$\",\"path\",null,{\"d\":\"M19 12H5\"}],[\"$\",\"path\",null,{\"d\":\"M12 19l-7-7 7-7\"}]]}],\"Back to Glossary\"]}]}]}]]}]}]\ne:null\n12:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\nd:null\n10:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"French Knot - Craft Glossary | Wook Wear\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"A small, raised embroidery stitch created by wrapping thread around the needle before inserting it back into the fabric. French knots add dot-like texture and are used for eyes, flower centers, and decorative accents.\"}],[\"$\",\"meta\",\"2\",{\"property\":\"og:title\",\"content\":\"Wook Wear | Handmade Pouches, Bags & Accessories\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:description\",\"content\":\"One-of-a-kind handmade pouches, bags, display mats & accessories by Meesh.\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:site_name\",\"content\":\"Wook Wear\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"7\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"8\",{\"name\":\"twitter:title\",\"content\":\"Wook Wear | Handmade by Meesh\"}],[\"$\",\"