\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\\\",\\\"children\\\":\\\"Sashiko\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-ww-text leading-relaxed line-clamp-2\\\",\\\"children\\\":\\\"A Japanese form of decorative reinforcement stitching that uses a simple running stitch to create geometric patterns. Originally used to mend and strengthen worn clothing, sashiko is now prized for its meditative process and striking visual texture.\\\"}]]}],[\\\"$\\\",\\\"$L4\\\",\\\"blanket-stitch\\\",{\\\"href\\\":\\\"/glossary/blanket-stitch\\\",\\\"className\\\":\\\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\\\",\\\"children\\\":\\\"Blanket Stitch\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-ww-text leading-relaxed line-clamp-2\\\",\\\"children\\\":\\\"A hand-sewing stitch used to finish raw edges, creating a series of evenly spaced loops along the fabric border. Each stitch locks the previous one in place, forming a durable and decorative edge binding.\\\"}]]}],[\\\"$\\\",\\\"$L4\\\",\\\"backstitch\\\",{\\\"href\\\":\\\"/glossary/backstitch\\\",\\\"className\\\":\\\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\\\",\\\"children\\\":\\\"Backstitch\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-ww-text leading-relaxed line-clamp-2\\\",\\\"children\\\":\\\"A strong hand stitch where the needle goes backward into the end of the previous stitch before moving forward, creating a continuous, unbroken line. It is one of the most durable hand stitches and closely mimics a machine lockstitch.\\\"}]]}],[\\\"$\\\",\\\"$L4\\\",\\\"running-stitch\\\",{\\\"href\\\":\\\"/glossary/running-stitch\\\",\\\"className\\\":\\\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\\\",\\\"children\\\":\\\"Running Stitch\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-ww-text leading-relaxed line-clamp-2\\\",\\\"children\\\":\\\"The most basic hand stitch, made by passing the needle in and out of the fabric at regular intervals. Simple and fast, it is used for basting, gathering, and decorative work like sashiko.\\\"}]]}],[\\\"$\\\",\\\"$L4\\\",\\\"whip-stitch\\\",{\\\"href\\\":\\\"/glossary/whip-stitch\\\",\\\"className\\\":\\\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-head font-black text-base text-ww-white mb-1 group-hover:text-ww-pink transition-colors\\\",\\\"children\\\":\\\"Whip Stitch\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-ww-text leading-relaxed line-clamp-2\\\",\\\"children\\\":\\\"A simple overcast stitch that wraps thread diagonally over a fabric edge, used to join two pieces together or finish raw edges. Quick to execute and useful for closing openings after turning a piece right side out.\\\"}]]}],[\\\"$\\\",\\\"$L4\\\",\\\"applique\\\",{\\\"href\\\":\\\"/glossary/applique\\\",\\\"className\\\":\\\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\\\",\\\"children\\\":[[\\\"