"},\"children\":[[\"$\",\"div\",null,{\"style\":{\"width\":\"28px\",\"height\":\"28px\",\"borderRadius\":\"8px\",\"background\":\"radial-gradient(circle at center, rgba(255,255,255,0.45) 0%, rgba(255,255,255,0.15) 40%, #B8892A 70%, #D4A63A 100%)\",\"boxShadow\":\"0 0 12px rgba(255,255,255,0.5), 0 0 24px rgba(255,255,255,0.2)\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"center\",\"flexShrink\":0},\"children\":[\"$\",\"svg\",null,{\"width\":\"14\",\"height\":\"14\",\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"strokeWidth\":\"2.5\",\"strokeLinecap\":\"round\",\"children\":[[\"$\",\"path\",null,{\"d\":\"M12 2L2 7l10 5 10-5-10-5z\",\"stroke\":\"#B8892A\",\"fill\":\"#FFFFFF\"}],[\"$\",\"path\",null,{\"d\":\"M2 12l10 5 10-5\",\"stroke\":\"#4A7CC9\"}],[\"$\",\"path\",null,{\"d\":\"M2 17l10 5 10-5\",\"stroke\":\"#B8892A\"}]]}]}],\"Built and managed by\",\" \",[\"$\",\"a\",null,{\"href\":\"https://webnari.io\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"style\":{\"color\":\"#B8892A\",\"fontWeight\":900,\"textDecoration\":\"none\"},\"children\":\"Webnari\"}]]}]}]],[\"$\",\"$L9\",null,{}],[\"$\",\"$La\",null,{}]]}]}]]}],{\"children\":[\"glossary\",[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L3\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}],{\"children\":[\"__PAGE__\",[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"min-h-screen pt-[120px] pb-24 max-md:pt-[100px] max-md:pb-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-[1200px] mx-auto px-10 max-md:px-5\",\"children\":[[\"$\",\"$Lb\",null,{\"className\":\"text-center mb-16\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 font-head text-[11px] font-bold tracking-[0.2em] uppercase text-ww-pink mb-5 justify-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"w-8 h-0.5 bg-[image:var(--gradient)] flex-shrink-0\"}],\"Craft Glossary\"]}],[\"$\",\"h1\",null,{\"className\":\"font-head font-black text-[clamp(42px,6vw,72px)] leading-[0.95] text-ww-white mb-6\",\"children\":[\"Know Your \",[\"$\",\"span\",null,{\"className\":\"gradient-text\",\"children\":\"Craft\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-lg text-ww-text max-w-[560px] mx-auto leading-relaxed\",\"children\":\"From stitches to fabrics to tools, here is every term you need to know as a maker.\"}]]}],[[\"$\",\"section\",\"techniques\",{\"className\":\"mb-16 last:mb-0\",\"children\":[[\"$\",\"$Lb\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4 mb-8\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-head font-black text-[clamp(28px,4vw,40px)] leading-[1.1] text-ww-white\",\"children\":\"Techniques\"}],[\"$\",\"span\",null,{\"className\":\"px-3 py-1 text-[11px] font-head font-bold tracking-[0.15em] uppercase rounded-full bg-[rgba(168,85,247,0.15)] text-ww-purple2\",\"children\":[19,\" terms\"]}]]}]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-2 gap-4 max-md:grid-cols-1\",\"children\":[[\"$\",\"$Lb\",\"sashiko\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/sashiko\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Sashiko\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A Japanese form of decorative reinforcement stitching that uses a simple running stitch to create geometric patterns. Originally used to mend and strengthen worn clothing, sashiko is now prized for its meditative process and striking visual texture.\"}]]}]}],[\"$\",\"$Lb\",\"blanket-stitch\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/blanket-stitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Blanket Stitch\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A hand-sewing stitch used to finish raw edges, creating a series of evenly spaced loops along the fabric border. Each stitch locks the previous one in place, forming a durable and decorative edge binding.\"}]]}]}],[\"$\",\"$Lb\",\"backstitch\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/backstitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Backstitch\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A strong hand stitch where the needle goes backward into the end of the previous stitch before moving forward, creating a continuous, unbroken line. It is one of the most durable hand stitches and closely mimics a machine lockstitch.\"}]]}]}],[\"$\",\"$Lb\",\"running-stitch\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/running-stitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Running Stitch\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The most basic hand stitch, made by passing the needle in and out of the fabric at regular intervals. Simple and fast, it is used for basting, gathering, and decorative work like sashiko.\"}]]}]}],[\"$\",\"$Lb\",\"whip-stitch\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/whip-stitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Whip Stitch\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A simple overcast stitch that wraps thread diagonally over a fabric edge, used to join two pieces together or finish raw edges. Quick to execute and useful for closing openings after turning a piece right side out.\"}]]}]}],[\"$\",\"$Lb\",\"applique\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/applique\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Applique\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A technique where pieces of fabric are layered and stitched onto a base fabric to create decorative shapes and designs. Applique can be done by hand or machine and adds dimension and visual interest to flat surfaces.\"}]]}]}],[\"$\",\"$Lb\",\"quilting\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/quilting\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Quilting\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The process of stitching together two or more layers of fabric, typically a decorative top, batting for insulation, and a backing layer. Quilting stitches hold the layers together while creating patterns on the surface.\"}]]}]}],[\"$\",\"$Lb\",\"patchwork\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/patchwork\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Patchwork\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A textile technique where small pieces of fabric are sewn together to create a larger design. Patchwork transforms scraps and offcuts into unique compositions and is the foundation of the Wook Wear aesthetic.\"}]]}]}],[\"$\",\"$Lb\",\"embroidery\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/embroidery\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Embroidery\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The art of decorating fabric with needle and thread or yarn, using a variety of stitches to create patterns, images, or text. Embroidery can be functional, decorative, or both.\"}]]}]}],[\"$\",\"$Lb\",\"cross-stitch\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/cross-stitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Cross-Stitch\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A form of embroidery that uses X-shaped stitches on an even-weave fabric to build up a pattern from a grid-based design. Popular for detailed pictorial work and text.\"}]]}]}],[\"$\",\"$Lb\",\"chain-stitch\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/chain-stitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Chain Stitch\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A looped embroidery stitch that creates a chain-like pattern on the fabric surface. Each new loop passes through the previous one, forming a decorative line that is thicker and more textured than a backstitch.\"}]]}]}],[\"$\",\"$Lb\",\"french-knot\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/french-knot\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"French Knot\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A small, raised embroidery stitch created by wrapping thread around the needle before inserting it back into the fabric. French knots add dot-like texture and are used for eyes, flower centers, and decorative accents.\"}]]}]}],[\"$\",\"$Lb\",\"topstitch\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/topstitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Topstitch\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A visible line of stitching sewn on the right side of the fabric, usually parallel to a seam or edge. Topstitching is both decorative and functional, keeping seam allowances flat and adding a polished finish.\"}]]}]}],[\"$\",\"$Lb\",\"edgestitch\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/edgestitch\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Edgestitch\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A line of stitching placed very close to a folded edge or seam, typically within an eighth of an inch. Edgestitching secures folds, keeps linings from rolling to the outside, and creates a crisp, professional finish.\"}]]}]}],[\"$\",\"$Lb\",\"basting\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/basting\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Basting\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"Temporary long stitches used to hold fabric layers in place before permanent sewing. Basting can be done by hand or machine and is removed after the final seam is sewn.\"}]]}]}],[\"$\",\"$Lb\",\"gathering\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/gathering\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Gathering\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A technique that draws fabric into soft folds by sewing a loose running stitch and then pulling the thread to bunch the material. Gathering creates ruffles, fullness, and dimensional texture in sewn projects.\"}]]}]}],[\"$\",\"$Lb\",\"hemming\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/hemming\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Hemming\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The process of folding and stitching a raw fabric edge to create a clean, finished border. Hems prevent fraying and give garments and textile projects a polished appearance.\"}]]}]}],[\"$\",\"$Lb\",\"darning\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/darning\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Darning\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A mending technique that repairs holes or worn areas by weaving new thread across the damaged section, rebuilding the fabric structure. Visible darning has become a popular decorative repair style.\"}]]}]}],[\"$\",\"$Lb\",\"felting\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/felting\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Felting\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The process of matting, condensing, and pressing fibers together to create a dense, non-woven fabric. Felting can be done with heat, moisture, and agitation (wet felting) or by repeatedly poking fibers with a barbed needle (needle felting).\"}]]}]}]]}]]}],[\"$\",\"section\",\"materials\",{\"className\":\"mb-16 last:mb-0\",\"children\":[[\"$\",\"$Lb\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4 mb-8\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-head font-black text-[clamp(28px,4vw,40px)] leading-[1.1] text-ww-white\",\"children\":\"Materials\"}],[\"$\",\"span\",null,{\"className\":\"px-3 py-1 text-[11px] font-head font-bold tracking-[0.15em] uppercase rounded-full bg-[rgba(168,85,247,0.15)] text-ww-purple2\",\"children\":[18,\" terms\"]}]]}]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-2 gap-4 max-md:grid-cols-1\",\"children\":[[\"$\",\"$Lb\",\"waxed-canvas\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/waxed-canvas\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Waxed Canvas\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"Cotton canvas treated with a wax-based coating that makes it water-resistant, durable, and beautifully patina-prone. Waxed canvas develops unique character marks over time and can be re-waxed when the finish wears thin.\"}]]}]}],[\"$\",\"$Lb\",\"sherpa\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/sherpa\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Sherpa\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A soft, curly-piled fabric that mimics the look and feel of sheep's wool. Typically made from polyester, sherpa has a bumpy textured side and a smooth knit backing, making it ideal for plush linings and cozy accents.\"}]]}]}],[\"$\",\"$Lb\",\"denim\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/denim\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Denim\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A sturdy cotton twill fabric woven with a diagonal rib pattern. Known for its durability and casual aesthetic, denim is a staple material for bags, pouches, and crossbody construction. It softens and fades beautifully with age.\"}]]}]}],[\"$\",\"$Lb\",\"corduroy\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/corduroy\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Corduroy\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A ridged fabric with raised parallel lines called wales, made from tufted cotton or cotton-blend fibers. Corduroy adds rich texture to patchwork and is valued for its soft hand feel and visual depth.\"}]]}]}],[\"$\",\"$Lb\",\"canvas\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/canvas\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Canvas\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A heavyweight, plain-weave cotton or cotton-blend fabric known for its strength and durability. Canvas is the workhorse of bag making, available in a wide range of weights from 4 oz to 18 oz per square yard.\"}]]}]}],[\"$\",\"$Lb\",\"felt\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/felt\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Felt\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A dense, non-woven textile made by matting fibers together through heat, moisture, or pressure. Felt does not fray when cut, making it useful for applique, small accessories, and decorative elements.\"}]]}]}],[\"$\",\"$Lb\",\"fleece\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/fleece\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Fleece\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A soft, synthetic fabric with a smooth, even pile on one or both sides. Lighter and flatter than sherpa, fleece is commonly used for linings, lightweight warmth layers, and comfortable bag interiors.\"}]]}]}],[\"$\",\"$Lb\",\"cotton\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/cotton\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Cotton\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A natural fiber harvested from the cotton plant, prized for its breathability, softness, and versatility. Cotton can be woven into everything from lightweight voile to heavy canvas and takes dye exceptionally well.\"}]]}]}],[\"$\",\"$Lb\",\"polyester\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/polyester\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Polyester\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A synthetic fiber made from petroleum-based polymers, valued for its durability, wrinkle resistance, and color retention. Polyester is used in sherpa, fleece, webbing, and many blended fabrics.\"}]]}]}],[\"$\",\"$Lb\",\"nylon\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/nylon\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Nylon\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A strong, lightweight synthetic fabric with excellent abrasion resistance and water repellency. Ripstop nylon is especially popular for bags and outdoor gear because of its tear-resistant gridded weave.\"}]]}]}],[\"$\",\"$Lb\",\"interfacing\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/interfacing\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Interfacing\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A support material applied to the back of fabric to add body, structure, and stability. Available in fusible (iron-on) and sew-in varieties, interfacing is essential for giving bags and pouches their shape.\"}]]}]}],[\"$\",\"$Lb\",\"batting\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/batting\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Batting\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A layer of soft, lofty material placed between fabric layers to add padding and insulation. Made from cotton, polyester, or wool, batting is commonly used in quilting and padded bag construction.\"}]]}]}],[\"$\",\"$Lb\",\"bias-tape\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/bias-tape\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Bias Tape\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"Narrow strips of fabric cut on the diagonal grain, which gives them stretch and allows them to curve smoothly around edges. Bias tape is used to bind raw edges, encase seam allowances, and add a clean finish.\"}]]}]}],[\"$\",\"$Lb\",\"binding-tape\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/binding-tape\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Binding Tape\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"Pre-folded tape used to encase and finish raw fabric edges. Similar to bias tape but may be cut on the straight grain, binding tape provides a clean, durable edge finish for bags, mats, and other textile projects.\"}]]}]}],[\"$\",\"$Lb\",\"webbing\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/webbing\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Webbing\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A strong, flat woven strip used for straps, handles, and reinforcement in bag construction. Typically made from nylon, polypropylene, or cotton, webbing carries heavy loads without stretching.\"}]]}]}],[\"$\",\"$Lb\",\"thread\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/thread\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Thread\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A thin, flexible strand of fiber used to sew materials together. Sewing thread comes in various weights and materials including cotton, polyester, and nylon, with heavier thread used for topstitching and structural seams.\"}]]}]}],[\"$\",\"$Lb\",\"yarn\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/yarn\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Yarn\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A long, continuous strand of twisted fibers used for knitting, crocheting, embroidery, and decorative stitching. Heavier than thread, yarn creates bold, visible stitches and textured effects.\"}]]}]}],[\"$\",\"$Lb\",\"fusible-web\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/fusible-web\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Fusible Web\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A thin adhesive material that bonds two fabric layers together when activated by heat from an iron. Fusible web is used for applique, hemming, and attaching patches without sewing.\"}]]}]}]]}]]}],[\"$\",\"section\",\"tools\",{\"className\":\"mb-16 last:mb-0\",\"children\":[[\"$\",\"$Lb\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4 mb-8\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-head font-black text-[clamp(28px,4vw,40px)] leading-[1.1] text-ww-white\",\"children\":\"Tools\"}],[\"$\",\"span\",null,{\"className\":\"px-3 py-1 text-[11px] font-head font-bold tracking-[0.15em] uppercase rounded-full bg-[rgba(168,85,247,0.15)] text-ww-purple2\",\"children\":[8,\" terms\"]}]]}]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-2 gap-4 max-md:grid-cols-1\",\"children\":[[\"$\",\"$Lb\",\"rotary-cutter\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/rotary-cutter\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Rotary Cutter\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A fabric-cutting tool with a circular rolling blade, similar to a pizza cutter. Rotary cutters make precise straight and curved cuts through multiple fabric layers and are used with a self-healing cutting mat.\"}]]}]}],[\"$\",\"$Lb\",\"cutting-mat\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/cutting-mat\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Cutting Mat\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A self-healing mat placed under fabric during rotary cutting to protect the work surface and extend blade life. Printed with grid lines and angle guides for accurate measuring and cutting.\"}]]}]}],[\"$\",\"$Lb\",\"seam-ripper\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/seam-ripper\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Seam Ripper\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A small, pointed tool used to cut and remove stitches when fixing mistakes or deconstructing seams. Every sewer's most-used tool and best friend, because mistakes are a normal part of the process.\"}]]}]}],[\"$\",\"$Lb\",\"bobbin\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/bobbin\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Bobbin\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A small spool that holds the lower thread in a sewing machine. The bobbin thread interlocks with the upper needle thread to form a lockstitch. Bobbins must be wound evenly and inserted correctly for smooth sewing.\"}]]}]}],[\"$\",\"$Lb\",\"presser-foot\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/presser-foot\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Presser Foot\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The part of a sewing machine that holds fabric flat against the feed dogs during stitching. Different presser feet are used for different tasks: a walking foot for thick layers, a zipper foot for close edges, and a Teflon foot for sticky fabrics.\"}]]}]}],[\"$\",\"$Lb\",\"thimble\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/thimble\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Thimble\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A small protective cap worn on the finger to push needles through heavy or layered fabric without injury. Essential for hand sewing through canvas, denim, and other thick materials.\"}]]}]}],[\"$\",\"$Lb\",\"pinking-shears\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/pinking-shears\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Pinking Shears\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"Scissors with zigzag-shaped blades that cut fabric in a sawtooth pattern. The zigzag edge reduces fraying on woven fabrics by cutting across the threads at an angle rather than straight across.\"}]]}]}],[\"$\",\"$Lb\",\"snap-setter\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/snap-setter\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Snap Setter\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A hand tool or plier-style press used to install metal snap fasteners into fabric. Snap setters apply even pressure to crimp snap components together, creating a secure, professional closure.\"}]]}]}]]}]]}],[\"$\",\"section\",\"construction\",{\"className\":\"mb-16 last:mb-0\",\"children\":[[\"$\",\"$Lb\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4 mb-8\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-head font-black text-[clamp(28px,4vw,40px)] leading-[1.1] text-ww-white\",\"children\":\"Construction\"}],[\"$\",\"span\",null,{\"className\":\"px-3 py-1 text-[11px] font-head font-bold tracking-[0.15em] uppercase rounded-full bg-[rgba(168,85,247,0.15)] text-ww-purple2\",\"children\":[11,\" terms\"]}]]}]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-2 gap-4 max-md:grid-cols-1\",\"children\":[[\"$\",\"$Lb\",\"seam-allowance\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/seam-allowance\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Seam Allowance\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The area between the stitching line and the raw edge of the fabric. Standard seam allowances range from a quarter inch for patchwork to five-eighths of an inch for garments. Consistent seam allowances are critical for pieces that fit together properly.\"}]]}]}],[\"$\",\"$Lb\",\"selvage\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/selvage\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Selvage\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The tightly woven finished edge that runs along both sides of a bolt of fabric, parallel to the warp threads. Selvage edges don't fray and are used as reference points for finding the grain line.\"}]]}]}],[\"$\",\"$Lb\",\"grain-line\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/grain-line\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Grain Line\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The direction of threads in a woven fabric. The lengthwise grain runs parallel to the selvage and has the least stretch. The crosswise grain runs perpendicular. The bias grain runs diagonally and has the most stretch.\"}]]}]}],[\"$\",\"$Lb\",\"warp-and-weft\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/warp-and-weft\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Warp and Weft\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The two sets of threads that form a woven fabric. Warp threads run lengthwise on the loom and are held under tension. Weft threads are woven horizontally across the warp. Together they create the fabric's structure and strength.\"}]]}]}],[\"$\",\"$Lb\",\"right-side-wrong-side\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/right-side-wrong-side\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Right Side / Wrong Side\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"The right side of fabric is the front, intended to be visible in the finished piece. The wrong side is the back. Most sewing is done with right sides facing together so seams end up hidden on the inside.\"}]]}]}],[\"$\",\"$Lb\",\"fat-quarter\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/fat-quarter\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Fat Quarter\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A pre-cut piece of fabric measuring approximately 18 by 22 inches, created by cutting a half yard of fabric in half across its width. Fat quarters are popular with quilters and patchwork makers because their squarish shape yields more usable pieces than a standard quarter yard.\"}]]}]}],[\"$\",\"$Lb\",\"quarter-inch-seam\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/quarter-inch-seam\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Quarter Inch Seam\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A narrow seam allowance commonly used in quilting and patchwork. Sewing exactly a quarter inch from the fabric edge ensures that pieced blocks come out to the correct finished size and that multiple pieces align properly.\"}]]}]}],[\"$\",\"$Lb\",\"bar-tack\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/bar-tack\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Bar Tack\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A dense cluster of closely spaced stitches used to reinforce high-stress points in a sewn item, such as strap attachments, pocket openings, and zipper ends. Bar tacks can withstand hundreds of pounds of pulling force.\"}]]}]}],[\"$\",\"$Lb\",\"grommet\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/grommet\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Grommet\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A metal or plastic ring inserted into a hole in fabric to reinforce the opening and prevent tearing. Grommets are commonly used for drawstrings, lacing, and ventilation holes in bags and pouches.\"}]]}]}],[\"$\",\"$Lb\",\"snap-closure\",{\"delay\":1,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/snap-closure\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Snap Closure\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A fastening system made of interlocking metal or plastic discs that click together when pressed. Snap closures are preferred on handmade bags for their ease of use, reliability, and satisfying tactile feedback.\"}]]}]}],[\"$\",\"$Lb\",\"piping\",{\"delay\":0,\"children\":[\"$\",\"$L4\",null,{\"href\":\"/glossary/piping\",\"className\":\"group block p-5 bg-ww-surface rounded-[16px] border border-ww-border transition-all hover:border-ww-purple hover:-translate-y-0.5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-head font-black text-lg text-ww-white mb-2 group-hover:text-ww-pink transition-colors\",\"children\":\"Piping\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-ww-text leading-relaxed line-clamp-2\",\"children\":\"A narrow fabric-covered cord inserted into a seam to create a raised decorative line along edges. Piping defines the shape of bags and cushions, adds visual contrast, and gives seams a professional, finished appearance.\"}]]}]}]]}]]}]]]}]}],null,[\"$\",\"$Lc\",null,{\"children\":[\"$Ld\",\"$Le\",[\"$\",\"$Lf\",null,{\"promise\":\"$@10\"}]]}]]}],{},null,false]},[[\"$\",\"div\",\"l\",{\"className\":\"min-h-screen pt-[120px] pb-24 max-md:pt-[100px] max-md:pb-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-[1200px] mx-auto px-10 max-md:px-5\",\"children\":[[\"$\",\"div\",null,{\"className\":\"skeleton h-4 w-40 mb-5\"}],[\"$\",\"div\",null,{\"className\":\"skeleton h-12 w-56 mb-10\"}],[\"$\",\"div\",null,{\"className\":\"space-y-3\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"skeleton h-16 w-full\",\"style\":\"$undefined\"}],[\"$\",\"div\",\"1\",{\"className\":\"skeleton h-16 w-full\",\"style\":\"$undefined\"}],[\"$\",\"div\",\"2\",{\"className\":\"skeleton h-16 w-full\",\"style\":\