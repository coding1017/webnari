{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/(storefront)/layout,_N_T_/(storefront)/about/layout,_N_T_/(storefront)/about/page,_N_T_/about"}},"html":"<!DOCTYPE html><html lang=\"en\" class=\"__variable_2c85f0 __variable_42943a\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/1f54c84255ccf44e-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/437e5f23c97e320c-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/5fb5c05ff73c0616-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/60c9b95e8d9e49be-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/61d96c4884191721-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/67d60655232d436d-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/79f0f365efbf4f90-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/b0bb26939bb40fdb-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" as=\"image\" href=\"/images/orange-buddy.jpg\"/><link rel=\"preload\" as=\"image\" href=\"/images/pat-profile.jpg\"/><link rel=\"preload\" as=\"image\" href=\"/images/jhudson-profile.jpg\"/><link rel=\"stylesheet\" href=\"/_next/static/css/c9bebc66c31d5150.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-12fda3ea80deff24.js\"/><script src=\"/_next/static/chunks/4bd1b696-533086a761637870.js\" async=\"\"></script><script src=\"/_next/static/chunks/1684-6d66eb399ac853a2.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-4a13c297ffb088e0.js\" async=\"\"></script><script src=\"/_next/static/chunks/6874-eeb4723d64d6a73b.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/(storefront)/about/page-bcafafdc63f6a454.js\" async=\"\"></script><script src=\"/_next/static/chunks/44530001-df39afff09c7cbe2.js\" async=\"\"></script><script src=\"/_next/static/chunks/8112-f1ccf3b90a18f34b.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/(storefront)/layout-b3cf8e559202ac5c.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/(storefront)/page-8b199964676eff8e.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>About Meesh | Wook Wear</title><meta name=\"description\" content=\"Meet Meesh, the maker behind Wook Wear. Handmade pouches, bags, and accessories crafted with love from the PNW.\"/><meta property=\"og:title\" content=\"Wook Wear | Handmade Pouches, Bags &amp; Accessories\"/><meta property=\"og:description\" content=\"One-of-a-kind handmade pouches, bags, display mats &amp; accessories by Meesh.\"/><meta property=\"og:site_name\" content=\"Wook Wear\"/><meta property=\"og:locale\" content=\"en_US\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Wook Wear | Handmade by Meesh\"/><meta name=\"twitter:description\" content=\"One-of-a-kind handmade pouches, bags &amp; accessories.\"/><link rel=\"icon\" href=\"/favicon.ico\" type=\"image/x-icon\" sizes=\"16x16\"/><script>document.querySelectorAll('body link[rel=\"icon\"], body link[rel=\"apple-touch-icon\"]').forEach(el => document.head.appendChild(el))</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><nav class=\"fixed top-0 left-0 right-0 z-[1000] h-[68px] bg-[rgba(10,5,20,0.88)] backdrop-blur-[14px] saturate-[180%] border-b border-[rgba(255,45,155,0.15)]\"><div class=\"max-w-[1200px] mx-auto h-full flex items-center px-10 max-md:px-5\"><a class=\"font-head font-black text-[22px] text-ww-white tracking-[0.06em] flex items-center gap-2.5\" href=\"/\">WOOK <span class=\"gradient-text\">WEAR</span></a><div class=\"hidden lg:flex items-center gap-1 ml-auto\"><a class=\"flex items-center px-4 py-2 text-sm font-medium text-ww-text rounded-[12px] transition-colors hover:text-ww-white hover:bg-[rgba(168,85,247,0.06)]\" href=\"/shop\">Shop</a><a class=\"flex items-center px-4 py-2 text-sm font-medium text-ww-text rounded-[12px] transition-colors hover:text-ww-white hover:bg-[rgba(168,85,247,0.06)] text-ww-pink\" href=\"/about\">About</a><a class=\"flex items-center px-4 py-2 text-sm font-medium text-ww-text rounded-[12px] transition-colors hover:text-ww-white hover:bg-[rgba(168,85,247,0.06)]\" href=\"/gallery\">Gallery</a><a class=\"flex items-center px-4 py-2 text-sm font-medium text-ww-text rounded-[12px] transition-colors hover:text-ww-white hover:bg-[rgba(168,85,247,0.06)]\" href=\"/contact\">Contact</a><div class=\"relative group\"><a class=\"flex items-center px-4 py-2 text-sm font-medium text-ww-text rounded-[12px] transition-colors hover:text-ww-white hover:bg-[rgba(168,85,247,0.06)]\" href=\"/blog\">Blog</a><div class=\"absolute top-full left-1/2 -translate-x-1/2 bg-ww-surface border border-ww-border rounded-lg p-1.5 min-w-[120px] opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all translate-y-1 group-hover:translate-y-0 shadow-[0_8px_24px_rgba(0,0,0,0.3)] z-[1001]\"><a class=\"block px-4 py-2 text-[13px] font-medium text-ww-text hover:text-ww-white hover:bg-[rgba(168,85,247,0.08)] rounded whitespace-nowrap\" href=\"/blog\">All Posts</a><a class=\"block px-4 py-2 text-[13px] font-medium text-ww-text hover:text-ww-white hover:bg-[rgba(168,85,247,0.08)] rounded whitespace-nowrap\" href=\"/glossary\">Craft Glossary</a></div></div></div><a class=\"relative flex items-center justify-center w-[42px] h-[42px] ml-3 lg:ml-3 max-lg:ml-auto rounded-[12px] hover:bg-[rgba(168,85,247,0.08)] transition-colors\" aria-label=\"Wishlist\" href=\"/wishlist\"><svg class=\"w-[20px] h-[20px] text-ww-text\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z\"></path></svg><span class=\"absolute top-0.5 right-0.5 min-w-[18px] h-[18px] bg-ww-pink text-ww-white font-head text-[10px] font-extrabold flex items-center justify-center rounded-full px-1 transition-all opacity-0 scale-50\">0</span></a><button class=\"relative flex items-center justify-center w-[42px] h-[42px] ml-1 rounded-[12px] hover:bg-[rgba(168,85,247,0.08)] transition-colors\" aria-label=\"Shopping cart\"><svg class=\"w-[22px] h-[22px] text-ww-text\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z\"></path><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"></line><path d=\"M16 10a4 4 0 01-8 0\"></path></svg><span class=\"absolute top-0.5 right-0.5 min-w-[18px] h-[18px] bg-ww-pink text-ww-white font-head text-[10px] font-extrabold flex items-center justify-center rounded-full px-1 transition-all opacity-0 scale-50\">0</span></button><button class=\"lg:hidden flex flex-col gap-[5px] bg-none border-none cursor-pointer p-1 z-[1001] ml-2\" aria-label=\"Menu\"><span class=\"block w-6 h-0.5 bg-ww-white transition-all duration-300\"></span><span class=\"block w-6 h-0.5 bg-ww-white transition-all duration-300\"></span><span class=\"block w-6 h-0.5 bg-ww-white transition-all duration-300\"></span></button></div></nav><div class=\"fixed top-[68px] w-[min(360px,85vw)] h-[calc(100vh-68px)] bg-[rgba(14,11,24,0.97)] backdrop-blur-[20px] border-l border-ww-border z-[999] p-8 px-7 overflow-y-auto transition-[right] duration-350 ease-[cubic-bezier(0.4,0,0.2,1)] -right-full\"><div class=\"mb-7\"><div class=\"font-head text-[10px] font-bold tracking-[0.2em] uppercase text-ww-muted mb-3 pb-2 border-b border-ww-border\">Menu</div><a class=\"block py-3 text-base text-ww-text border-b border-[rgba(42,34,68,0.3)] hover:text-ww-pink2 transition-colors\" href=\"/shop\">Shop</a><a class=\"block py-3 text-base text-ww-text border-b border-[rgba(42,34,68,0.3)] hover:text-ww-pink2 transition-colors\" href=\"/about\">About</a><a class=\"block py-3 text-base text-ww-text border-b border-[rgba(42,34,68,0.3)] hover:text-ww-pink2 transition-colors\" href=\"/gallery\">Gallery</a><a class=\"block py-3 text-base text-ww-text border-b border-[rgba(42,34,68,0.3)] hover:text-ww-pink2 transition-colors\" href=\"/contact\">Contact</a><a class=\"block py-3 text-base text-ww-text border-b border-[rgba(42,34,68,0.3)] hover:text-ww-pink2 transition-colors\" href=\"/blog\">Blog</a></div><div class=\"mb-7\"><div class=\"font-head text-[10px] font-bold tracking-[0.2em] uppercase text-ww-muted mb-3 pb-2 border-b border-ww-border\">Follow</div><a href=\"https://www.instagram.com/wook.wear\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"block py-3 text-base text-ww-text hover:text-ww-pink2 transition-colors\">Instagram @wook.wear</a></div><a class=\"flex items-center justify-center gap-2.5 py-3.5 px-6 bg-[image:var(--gradient)] text-ww-white font-head text-sm font-extrabold tracking-[0.08em] uppercase rounded-[12px] mt-4\" href=\"/shop\">Shop the Drop</a></div><main><div class=\"min-h-screen pt-[120px] pb-0 max-md:pt-[100px]\"><section class=\"text-center pb-20 max-md:pb-12\"><div class=\"max-w-[1200px] mx-auto px-10 max-md:px-5\"><div class=\"reveal\"><div class=\"flex items-center gap-3 font-head text-[11px] font-bold tracking-[0.2em] uppercase text-ww-pink mb-5 justify-center\"><span class=\"w-8 h-0.5 bg-[image:var(--gradient)] flex-shrink-0\"></span>The Story</div><h1 class=\"font-head font-black text-[clamp(42px,6vw,72px)] leading-[0.95] text-ww-white mb-6\">Meet the <span class=\"gradient-text\">Maker</span></h1><p class=\"text-lg text-ww-text max-w-[560px] mx-auto leading-relaxed\">Every stitch, every cut, every detail is done by hand. This is Wook Wear, and it all starts with Meesh.</p></div></div></section><section class=\"py-24 bg-ww-dark relative overflow-hidden max-md:py-16\"><div class=\"max-w-[1200px] mx-auto px-10 max-md:px-5\"><div class=\"grid grid-cols-[1.2fr_1fr] gap-16 items-center max-lg:grid-cols-1 max-lg:gap-10\"><div class=\"reveal\"><div class=\"aspect-[4/5] rounded-[20px] overflow-hidden border border-ww-border\"><img src=\"/images/orange-buddy.jpg\" alt=\"Meesh showing off a handmade Orange Sherpa Buddy Pouch\" class=\"w-full h-full object-cover\"/></div></div><div class=\"reveal reveal-delay-1\"><div class=\"flex items-center gap-3 font-head text-[11px] font-bold tracking-[0.2em] uppercase text-ww-pink mb-5\"><span class=\"w-8 h-0.5 bg-[image:var(--gradient)] flex-shrink-0\"></span>The Maker</div><h2 class=\"font-head font-black text-[clamp(36px,5vw,56px)] leading-[1.05] text-ww-white mb-5\">How It All <span class=\"gradient-text\">Started</span></h2><p class=\"text-ww-text text-base leading-[1.7] mb-5\">Wook Wear started the way most good things do: with a sewing machine, a pile of fabric, and a late-night idea that just wouldn&#x27;t quit. Meesh had always been drawn to pattern-making and the feel of working with her hands, but it wasn&#x27;t until she started making pouches for friends heading to festivals that things really clicked.</p><p class=\"text-ww-text text-base leading-[1.7] mb-5\">What began as Instagram drops and word-of-mouth sales quickly grew into something bigger. Festival-goers, collectors, and fellow makers started reaching out, and Wook Wear found its community.</p><p class=\"text-ww-text text-base leading-[1.7]\">No two pieces are ever the same. That&#x27;s not a limitation -- it&#x27;s the whole point. Each creation carries its own personality, from the fabric selection to the final stitch. It&#x27;s wearable art, made one piece at a time.</p></div></div></div></section><section class=\"py-24 relative overflow-hidden max-md:py-16\"><div class=\"max-w-[1200px] mx-auto px-10 max-md:px-5\"><div class=\"reveal text-center\"><div class=\"flex items-center gap-3 font-head text-[11px] font-bold tracking-[0.2em] uppercase text-ww-pink mb-5 justify-center\"><span class=\"w-8 h-0.5 bg-[image:var(--gradient)] flex-shrink-0\"></span>From Sketch to Stitch</div><h2 class=\"font-head font-black text-[clamp(36px,5vw,56px)] leading-[1.05] text-ww-white mb-5\">How It&#x27;s <span class=\"gradient-text\">Made</span></h2></div><div class=\"grid grid-cols-4 gap-6 mt-12 max-lg:grid-cols-2 max-md:gap-4\"><div class=\"reveal reveal-delay-1\"><div class=\"bg-ww-surface border border-ww-border rounded-[20px] p-7 text-center transition-all duration-300 hover:-translate-y-1 hover:border-ww-purple/50 hover:shadow-[0_8px_32px_rgba(168,85,247,0.12)]\"><div class=\"w-14 h-14 mx-auto mb-4 rounded-full bg-[rgba(168,85,247,0.1)] border border-[rgba(168,85,247,0.2)] flex items-center justify-center text-ww-purple2\"><svg class=\"w-8 h-8\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"><path d=\"M12 19l7-7 3 3-7 7-3-3z\"></path><path d=\"M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z\"></path><path d=\"M2 2l7.586 7.586\"></path><circle cx=\"11\" cy=\"11\" r=\"2\"></circle></svg></div><div class=\"font-head text-[10px] font-bold tracking-[0.2em] text-ww-pink mb-2\">01</div><div class=\"font-head font-extrabold text-lg text-ww-white uppercase tracking-[0.06em] mb-2\">Design</div><p class=\"text-sm text-ww-text leading-relaxed\">Every piece starts as a sketch or a vision. Meesh draws patterns and picks fabrics that speak to her.</p></div></div><div class=\"reveal reveal-delay-2\"><div class=\"bg-ww-surface border border-ww-border rounded-[20px] p-7 text-center transition-all duration-300 hover:-translate-y-1 hover:border-ww-purple/50 hover:shadow-[0_8px_32px_rgba(168,85,247,0.12)]\"><div class=\"w-14 h-14 mx-auto mb-4 rounded-full bg-[rgba(168,85,247,0.1)] border border-[rgba(168,85,247,0.2)] flex items-center justify-center text-ww-purple2\"><svg class=\"w-8 h-8\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"><circle cx=\"6\" cy=\"6\" r=\"3\"></circle><circle cx=\"6\" cy=\"18\" r=\"3\"></circle><line x1=\"20\" y1=\"4\" x2=\"8.12\" y2=\"15.88\"></line><line x1=\"14.47\" y1=\"14.48\" x2=\"20\" y2=\"20\"></line><line x1=\"8.12\" y1=\"8.12\" x2=\"12\" y2=\"12\"></line></svg></div><div class=\"font-head text-[10px] font-bold tracking-[0.2em] text-ww-pink mb-2\">02</div><div class=\"font-head font-extrabold text-lg text-ww-white uppercase tracking-[0.06em] mb-2\">Cut &amp; Sew</div><p class=\"text-sm text-ww-text leading-relaxed\">Each piece is hand-cut and sewn on Meesh&#x27;s trusty machine. No two cuts are ever the same.</p></div></div><div class=\"reveal reveal-delay-3\"><div class=\"bg-ww-surface border border-ww-border rounded-[20px] p-7 text-center transition-all duration-300 hover:-translate-y-1 hover:border-ww-purple/50 hover:shadow-[0_8px_32px_rgba(168,85,247,0.12)]\"><div class=\"w-14 h-14 mx-auto mb-4 rounded-full bg-[rgba(168,85,247,0.1)] border border-[rgba(168,85,247,0.2)] flex items-center justify-center text-ww-purple2\"><svg class=\"w-8 h-8\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"></polygon></svg></div><div class=\"font-head text-[10px] font-bold tracking-[0.2em] text-ww-pink mb-2\">03</div><div class=\"font-head font-extrabold text-lg text-ww-white uppercase tracking-[0.06em] mb-2\">Details</div><p class=\"text-sm text-ww-text leading-relaxed\">Snaps, zippers, piping, and patches are added by hand. The details make it special.</p></div></div><div class=\"reveal reveal-delay-4\"><div class=\"bg-ww-surface border border-ww-border rounded-[20px] p-7 text-center transition-all duration-300 hover:-translate-y-1 hover:border-ww-purple/50 hover:shadow-[0_8px_32px_rgba(168,85,247,0.12)]\"><div class=\"w-14 h-14 mx-auto mb-4 rounded-full bg-[rgba(168,85,247,0.1)] border border-[rgba(168,85,247,0.2)] flex items-center justify-center text-ww-purple2\"><svg class=\"w-8 h-8\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"><path d=\"M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z\"></path></svg></div><div class=\"font-head text-[10px] font-bold tracking-[0.2em] text-ww-pink mb-2\">04</div><div class=\"font-head font-extrabold text-lg text-ww-white uppercase tracking-[0.06em] mb-2\">Ship with Love</div><p class=\"text-sm text-ww-text leading-relaxed\">Wrapped up with stickers and care, every order is packed like a gift.</p></div></div></div></div></section><section class=\"py-24 bg-ww-dark relative overflow-hidden max-md:py-16\"><div class=\"max-w-[1200px] mx-auto px-10 max-md:px-5\"><div class=\"reveal\"><div class=\"flex items-center gap-3 font-head text-[11px] font-bold tracking-[0.2em] uppercase text-ww-pink mb-5\"><span class=\"w-8 h-0.5 bg-[image:var(--gradient)] flex-shrink-0\"></span>Better Together</div><h2 class=\"font-head font-black text-[clamp(36px,5vw,56px)] leading-[1.05] text-ww-white mb-5\">The Collab <span class=\"gradient-text\">Crew</span></h2><p class=\"text-ww-text text-base leading-[1.7] max-w-[640px] mb-10\">Wook Wear wouldn&#x27;t be what it is without the incredible makers and creatives who inspire, collaborate, and push the craft forward.</p></div><div class=\"grid grid-cols-2 gap-8 max-lg:grid-cols-1\"><div class=\"reveal reveal-delay-1\"><a href=\"https://www.instagram.com/_powerpat\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"flex gap-5 bg-ww-surface border border-ww-border rounded-[20px] p-6 transition-all duration-300 hover:border-ww-purple/50 hover:shadow-[0_8px_32px_rgba(168,85,247,0.12)] max-md:flex-col max-md:items-center max-md:text-center\"><div class=\"w-20 h-20 rounded-full overflow-hidden flex-shrink-0 border-2 border-ww-border\"><img src=\"/images/pat-profile.jpg\" alt=\"Power Pat\" class=\"w-full h-full object-cover\"/></div><div><div class=\"font-head font-extrabold text-lg text-ww-white\">Power Pat</div><div class=\"text-sm text-ww-pink mb-2\">@_powerpat</div><p class=\"text-sm text-ww-text leading-relaxed\">Creative partner and hype squad. Pat brings fresh ideas, feedback, and energy to every drop. A key part of the Wook Wear universe.</p></div></a></div><div class=\"reveal reveal-delay-2\"><a href=\"https://www.instagram.com/jhudson_tiedye\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"flex gap-5 bg-ww-surface border border-ww-border rounded-[20px] p-6 transition-all duration-300 hover:border-ww-purple/50 hover:shadow-[0_8px_32px_rgba(168,85,247,0.12)] max-md:flex-col max-md:items-center max-md:text-center\"><div class=\"w-20 h-20 rounded-full overflow-hidden flex-shrink-0 border-2 border-ww-border\"><img src=\"/images/jhudson-profile.jpg\" alt=\"J Hudson\" class=\"w-full h-full object-cover\"/></div><div><div class=\"font-head font-extrabold text-lg text-ww-white\">J Hudson</div><div class=\"text-sm text-ww-pink mb-2\">@jhudson_tiedye</div><p class=\"text-sm text-ww-text leading-relaxed\">Tie-dye artist extraordinaire. J creates the vibrant, one-of-a-kind dyed fabrics that give many Wook Wear pieces their signature color and energy.</p></div></a></div></div></div></section><section class=\"py-24 relative overflow-hidden max-md:py-16\"><div class=\"max-w-[1200px] mx-auto px-10 max-md:px-5\"><div class=\"reveal text-center\"><div class=\"flex items-center gap-3 font-head text-[11px] font-bold tracking-[0.2em] uppercase text-ww-pink mb-5 justify-center\"><span class=\"w-8 h-0.5 bg-[image:var(--gradient)] flex-shrink-0\"></span>In the Spotlight</div><h2 class=\"font-head font-black text-[clamp(36px,5vw,56px)] leading-[1.05] text-ww-white mb-10\">As Seen <span class=\"gradient-text\">In</span></h2></div><div class=\"reveal\"><div class=\"max-w-[640px] mx-auto bg-ww-surface border border-ww-border rounded-[20px] p-8 text-center\"><div class=\"font-head text-[10px] font-bold tracking-[0.2em] uppercase text-ww-cyan mb-3\">Featured In</div><div class=\"font-head font-black text-2xl text-ww-white mb-3\">Leafy Magazine</div><p class=\"text-sm text-ww-text leading-relaxed\">Wook Wear was featured in Leafy Magazine for pushing the boundaries of handmade festival accessories. From one-of-a-kind pouches to bold display mats, the feature highlighted Meesh&#x27;s commitment to craft and community.</p></div></div></div></section><section class=\"py-24 text-center bg-ww-dark max-md:py-16\"><div class=\"max-w-[1200px] mx-auto px-10 max-md:px-5\"><div class=\"reveal\"><h2 class=\"font-head font-black text-[clamp(28px,4vw,42px)] leading-[1.1] text-ww-white mb-8\">Want to collab or just say hi?</h2><div class=\"flex gap-4 justify-center flex-wrap\"><a class=\"inline-flex items-center gap-2 py-3.5 px-7 font-head text-sm font-extrabold tracking-[0.08em] uppercase rounded-[12px] bg-[image:var(--gradient)] text-ww-white shadow-[0_0_24px_rgba(255,45,155,0.2)] hover:shadow-[0_0_40px_rgba(255,45,155,0.35)] hover:-translate-y-0.5 transition-all\" href=\"/contact\">Get in Touch</a><a href=\"https://www.instagram.com/wook.wear\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"inline-flex items-center gap-2 py-3.5 px-7 font-head text-sm font-extrabold tracking-[0.08em] uppercase rounded-[12px] bg-transparent text-ww-white border border-ww-border hover:border-ww-purple hover:text-ww-purpl